SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_publishable_or_service_key
SUPABASE_TABLE=todo
SUPABASE_USER_FIELD=user_uuid
SUPABASE_USER_UUID=your-user-uuid

TODO_ID_FIELD=id
TODO_TITLE_FIELD=title
TODO_BODY_FIELD=description
TODO_DUE_AT_FIELD=due_at
TODO_DONE_FIELD=completed
TODO_DONE_TRUE_VALUES=true,1,done,completed
TODO_STATUS_FIELD=
TODO_DONE_STATUS_VALUES=done,completed
TODO_CREATED_AT_FIELD=created_at
TODO_UPDATED_AT_FIELD=updated_at

LLM_API_URL=https://cloud.infini-ai.com/maas/glm-5/nvidia/chat/completions
LLM_API_KEY=your_infini_key
LLM_MODEL=glm-5

WEIXIN_DELIVERY_MODE=openclaw
ZCLAW_WEIXIN_DIR=
WEIXIN_ACCOUNT=

# Optional: only needed when WEIXIN_DELIVERY_MODE=mqtt
MQTT_URI=mqtts://example-broker:8883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC=zclaw

ZCLAW_NOTIFIER_TIMEZONE=Asia/Shanghai
ZCLAW_NOTIFIER_POLL_INTERVAL_MS=60000
ZCLAW_DAILY_SUMMARY_HOUR=21
ZCLAW_DAILY_SUMMARY_MINUTE=0
ZCLAW_WEEKLY_SUMMARY_WEEKDAY=7
ZCLAW_WEEKLY_SUMMARY_HOUR=21
ZCLAW_WEEKLY_SUMMARY_MINUTE=30

# 可选：如果不想依赖 bridge 学习到的默认联系人，也可以直接指定
WEIXIN_TO_USER_ID=
WEIXIN_CONTEXT_TOKEN=
