# Shared workspace settings

# Desktop -> API
ADHD_API_URL=http://127.0.0.1:8000
ROVIA_SIDECAR_URL=ws://127.0.0.1:8000/ws/telemetry

# Shared Supabase settings
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=
ADHD_USER_ID=
ROVIA_USER_ID=

# API backend switches
ENABLE_BLE_RUNNER=1
# 默认不预设设备名，运行时从扫描页选择
WRISTBAND_DEVICE_NAME=
WRISTBAND_NOTIFY_CHAR_UUID=beb5483e-36e1-4688-b7f5-ea07361b26a8
WRISTBAND_ALERT_CHAR_UUID=
SQUEEZE_DEVICE_NAME=
SQUEEZE_NOTIFY_CHAR_UUID=
SQUEEZE_WRITE_CHAR_UUID=
BLE_SCAN_INTERVAL_S=3
BLE_RECONNECT_INTERVAL_S=5
BLE_DEVICE_TIMEOUT_S=15
BLE_READ_FALLBACK_AFTER_S=6
RSSI_ENTER_DESK=-58
RSSI_LEAVE_DESK=-63
SUPABASE_SYNC_INTERVAL_S=12

# zclaw note:
# zclaw still uses its own provisioning and runtime scripts under device/zclaw/scripts.
