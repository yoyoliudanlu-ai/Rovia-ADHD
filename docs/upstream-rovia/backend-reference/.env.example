SUPABASE_URL=
SUPABASE_KEY=
ADHD_USER_ID=

# 关闭时只调试 HTTP / WS，不启动 BLE 线程
ENABLE_BLE_RUNNER=1

# 手环
WRISTBAND_DEVICE_NAME=ZhiYa-Wristband
WRISTBAND_NOTIFY_CHAR_UUID=beb5483e-36e1-4688-b7f5-ea07361b26a8
# 可选：用于离位提醒回写
WRISTBAND_ALERT_CHAR_UUID=

# 捏捏
SQUEEZE_DEVICE_NAME=ZhiYa-NieNie
# 如果已知真实输入特征再填；不填则后端会自动探测 notify/read 特征
SQUEEZE_NOTIFY_CHAR_UUID=
SQUEEZE_WRITE_CHAR_UUID=

# BLE 节奏
BLE_SCAN_INTERVAL_S=3
BLE_RECONNECT_INTERVAL_S=5
BLE_DEVICE_TIMEOUT_S=15
BLE_READ_FALLBACK_AFTER_S=6

# 在位阈值
RSSI_ENTER_DESK=-58
RSSI_LEAVE_DESK=-63

# Supabase 遥测上报频率
SUPABASE_SYNC_INTERVAL_S=12
